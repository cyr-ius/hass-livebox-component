// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "Python 3",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "mcr.microsoft.com/devcontainers/python:3-3.14-trixie",
  "features": {
    "ghcr.io/devcontainers-extra/features/prek:1": {},
    "ghcr.io/devcontainers-extra/features/uv:1": {}
  },
  "postCreateCommand": "git config --global --add safe.directory ${containerWorkspaceFolder} && prek install --overwrite && uv sync --group dev --link-mode=copy",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "esbenp.prettier-vscode",
        "ms-vscode-remote.remote-containers",
        "streetsidesoftware.code-spell-checker",
        "anthropic.claude-code"
      ],
      "settings": {
        // ── Python ──────────────────────────────────────────────────────
        "python.terminal.activateEnvInCurrentTerminal": true,
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"],
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.formatOnPaste": false,
          "editor.formatOnType": true,
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        },
        "ruff.enable": true,
        "ruff.organizeImports": true,
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[yaml]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        // ── Général ──────────────────────────────────────────────────────
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "files.eol": "\n",
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": true
      }
    }
  },
  "mounts": [
    "source=${env:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ]
}
